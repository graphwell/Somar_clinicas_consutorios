generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Clinica {
  id             String        @id @default(uuid())
  tenantId       String        @unique
  slug           String        @unique @default("clinica-default")
  nome           String
  nicho          NichoType     @default(CLINICA_MEDICA)
  configBranding Json?         // { logoUrl, primaryColor, etc }
  razaoSocial    String?
  cnpj           String?
  endereco       String?
  adminPhone     String?
  botActive      Boolean       @default(true)
  onboardingCompleted Boolean  @default(false)
  multiProfissional   Boolean  @default(false)
  openingTime         String   @default("08:00")
  closingTime         String   @default("18:00")
  workingDays         String   @default("1,2,3,4,5")
  usuarios       Usuario[]
  pacientes      Paciente[]
  agendamentos   Agendamento[]
  profissionais  Profissional[]
  convenios      ConvenioEmpresa[]
  notificacoes   Notificacao[]
  servicos       Servico[]
  combosUpsell   ComboUpsell[]
  campanhasAviso CampanhaAviso[]
  transacoes     TransacaoFinanceira[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("clinicas")
  planosAssinatura     PlanoAssinatura[]
  integracoes          ClinicIntegration[]
  whatsappInstances    WhatsappInstance[]
  prontuarios          ProntuarioRegistro[]
  odontogramaItens     OdontogramaItem[]
  odontogramaHistorico OdontogramaHistorico[]
}

enum NichoType {
  CLINICA_MEDICA
  CLINICA_MULTI
  CLINICA_ESTETICA
  SALAO_BELEZA
  BARBEARIA
  FISIOTERAPIA
  ODONTOLOGIA
  NUTRICAO
  OUTRO
}

model Usuario {
  id             String        @id @default(uuid())
  nome           String?
  email          String        @unique
  senhaHash      String
  role           String        @default("recepcao") // admin, recepcao, profissional
  tenantId       String
  profissionalId String?       // preenchido quando role=profissional
  clinica        Clinica       @relation(fields: [tenantId], references: [tenantId])
  profissional   Profissional? @relation(fields: [profissionalId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("usuarios")
}

model Paciente {
  id              String        @id @default(uuid())
  nome            String
  telefone        String
  dataNascimento  DateTime?
  convenio        String?
  tipoAtendimento String        @default("particular")
  
  // Stats V2
  totalGasto      Float         @default(0.0)
  ultimaVisita    DateTime?
  contagemVisitas Int           @default(0)

  isSubscriber          Boolean  @default(false)
  profissionalPreferidoId String?
  cpf                   String?   // New field for patient identification
  deletedAt             DateTime?

  tenantId        String
  clinica         Clinica       @relation(fields: [tenantId], references: [tenantId])
  agendamentos    Agendamento[]
  assinaturas     AssinaturaCliente[]
  prontuarios     ProntuarioRegistro[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("pacientes")
}

model Profissional {
  id           String        @id @default(uuid())
  nome         String
  especialidade String?
  registroProfissional String?
  bio          String?
  fotoUrl      String?
  color        String?       @default("#4a4ae2")
  horariosJson Json?         // Legacy (keep for compatibility if needed)
  ativo        Boolean       @default(true)
  tenantId     String
  clinica      Clinica       @relation(fields: [tenantId], references: [tenantId])
  agendamentos Agendamento[]
  escalas      ProfessionalSchedule[]
  servicos     Servico[]     // Many-to-many with services
  usuarios     Usuario[]
  prontuarios  ProntuarioRegistro[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("profissionais")
}

model ProfessionalSchedule {
  id             String       @id @default(uuid())
  profissionalId String
  diaSemana      Int          // 0-6
  horaInicio     String       // "08:00"
  horaFim        String       // "18:00"
  lunchStart     String?      // "12:00"
  lunchEnd       String?      // "13:00"
  ativo          Boolean      @default(true)
  profissional   Profissional @relation(fields: [profissionalId], references: [id])

  @@map("professional_schedules")
}

model ConvenioEmpresa {
  id           String   @id @default(uuid())
  nomeConvenio String
  ativo        Boolean  @default(true)
  tenantId     String
  clinica      Clinica  @relation(fields: [tenantId], references: [tenantId])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("convenios_empresa")
}

model NichoConfig {
  id                 String   @id @default(uuid())
  nomeNicho          String   @unique
  labelCliente       String   @default("Cliente")
  labelServico       String   @default("Serviço")
  labelProfissional  String   @default("Profissional")
  servicosPadraoJson Json?    // Array of default services

  @@map("nichos_config")
}

model Agendamento {
  id              String        @id @default(uuid())
  pacienteId      String
  profissionalId  String?
  dataHora        DateTime      // Início
  fimDataHora     DateTime      // Fim (Início + duration)
  durationMinutes Int           @default(30)
  status          String        @default("pendente") // confirmado, pendente, cancelado, done
  eventoId        String        @unique 
  categoria       String?       @default("consulta") // primeira, consulta, retorno
  convenio        String?
  tipoAtendimento String        @default("particular")
  tenantId        String
  clinica         Clinica       @relation(fields: [tenantId], references: [tenantId])
  paciente        Paciente      @relation(fields: [pacienteId], references: [id])
  profissional    Profissional? @relation(fields: [profissionalId], references: [id])
  servicoId       String?
  servico         Servico?      @relation(fields: [servicoId], references: [id])
  
  observacoes     String?
  transacao       TransacaoFinanceira?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("agendamentos")
}

model TransacaoFinanceira {
  id             String       @id @default(uuid())
  tenantId       String
  tipo           String       @default("income") // income, expense
  status         String       @default("pending") // pending, previsto, realizado, canceled
  valor          Float        @default(0.0)
  descricao      String?
  categoria      String?      @default("Geral")
  agendamentoId  String?      @unique
  
  clinica        Clinica      @relation(fields: [tenantId], references: [tenantId])
  agendamento    Agendamento? @relation(fields: [agendamentoId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("transacoes_financeiras")
}

model AiLog {
  id        String   @id @default(uuid())
  mensagem  String
  createdAt DateTime @default(now())

  @@map("ai_logs")
}

model InviteToken {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String
  role      String   @default("recepcao")
  tenantId  String
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("invite_tokens")
}

model Assinatura {
  id                 String    @id @default(uuid())
  tenantId           String    @unique
  stripeCustomerId   String?
  stripeSubId        String?
  plano              String    @default("starter") // starter, pro, enterprise
  status             String    @default("trial")   // trial, active, past_due, canceled
  updatedAt          DateTime  @updatedAt

  @@map("assinaturas")
}

model Servico {
  id               String   @id @default(uuid())
  nome             String
  descricao        String?
  duracaoMinutos   Int      @default(30)
  bufferTimeMinutes Int     @default(0)
  preco            Float    @default(0.0)
  color            String?  @default("#3B82F6")
  nicho            String?
  ativo            Boolean  @default(true)
  tenantId         String
  clinica          Clinica  @relation(fields: [tenantId], references: [tenantId])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  profissionais    Profissional[] // Many-to-many with professionals
  gatilhosUpsell   ComboUpsell[] @relation("GatilhoUpsell")
  ofertasUpsell    ComboUpsell[] @relation("OfertaUpsell")
  agendamentos     Agendamento[]

  @@map("servicos")
}

model ComboUpsell {
  idItem               String   @id @default(uuid()) @map("id")
  tenantId             String
  servicoGatilhoId     String
  servicoOferecidoId   String
  descricaoOferta      String
  desconto             Float    @default(0.0)
  ativo                Boolean  @default(true)
  
  clinica              Clinica  @relation(fields: [tenantId], references: [tenantId])
  gatilho              Servico  @relation("GatilhoUpsell", fields: [servicoGatilhoId], references: [id])
  oferta               Servico  @relation("OfertaUpsell", fields: [servicoOferecidoId], references: [id])
  createdAt            DateTime @default(now())

  @@map("combos_upsell")
}

model CampanhaAviso {
  id                   String   @id @default(uuid())
  tenantId             String
  titulo               String
  mensagem             String
  segmentoFiltrosJson  String?  // JSON string
  dataEnvio            DateTime?
  status               String   @default("pendente") // pendente, enviado, cancelado
  totalEnviado         Int      @default(0)
  
  clinica              Clinica  @relation(fields: [tenantId], references: [tenantId])
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("campanhas_aviso")
}

model Notificacao {
  id        String   @id @default(uuid())
  tenantId  String
  titulo    String
  mensagem  String
  lida      Boolean  @default(false)
  clinica   Clinica  @relation(fields: [tenantId], references: [tenantId])
  createdAt DateTime @default(now())

  @@map("notificacoes")
}

model PlanoAssinatura {
  id          String   @id @default(cuid())
  empresaId   String
  nome        String   // ex: "Corte + Barba"
  descricao   String?
  valor       Float    // Usando Float para consistência com o restante do projeto
  periodicidade String // "mensal" | "trimestral"
  servicos    Json     // lista de serviços incluídos
  ativo       Boolean  @default(true)
  tenantId    String
  clinica     Clinica  @relation(fields: [tenantId], references: [tenantId])
  assinantes  AssinaturaCliente[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("planos_assinatura")
}

model AssinaturaCliente {
  id          String   @id @default(cuid())
  pacienteId  String   
  planoId     String
  dataInicio  DateTime @default(now())
  dataFim     DateTime?
  status      String   @default("ativo") // "ativo" | "cancelado" | "vencido"
  valorPago   Float
  paciente    Paciente @relation(fields: [pacienteId], references: [id])
  plano       PlanoAssinatura @relation(fields: [planoId], references: [id])
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("assinaturas_cliente")
}

model ClinicIntegration {
  id        String   @id @default(cuid())
  tenantId  String
  type      String   // "whatsapp", "stripe", "mercadopago", "n8n"
  status    String   @default("inactive") // "active", "inactive", "error"
  config    Json?    // API keys, Webhook URLs, etc.
  clinica   Clinica  @relation(fields: [tenantId], references: [tenantId])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clinic_integrations")
}

enum WhatsappStatus {
  LIVRE
  EM_USO
  DEMO
  OFFLINE
  AGUARDANDO
}

enum WhatsappPlataforma {
  WASENDERAPI
  ULTRAMSG
}

model WhatsappInstance {
  id           String              @id @default(cuid())
  empresaId    String?
  sessionId    String              @unique
  bearerToken  String
  numeroWa     String?
  status       WhatsappStatus      @default(LIVRE)
  plataforma   WhatsappPlataforma  @default(WASENDERAPI)
  webhookUrl   String?
  observacoes  String?
  criadoEm     DateTime            @default(now())
  conectadoEm  DateTime?
  ultimoPing   DateTime?
  empresa      Clinica?            @relation(fields: [empresaId], references: [tenantId])

  @@map("whatsapp_instances")
}

// ─── Prontuário Digital ──────────────────────────────────────

model ProntuarioRegistro {
  id             String   @id @default(cuid())
  pacienteId     String
  tenantId       String
  profissionalId String?
  tipo           String   // CLINICO | ODONTOLOGICO | NUTRICIONAL
  agendamentoId  String?

  // Campos clínicos gerais
  queixaPrincipal     String?
  historiaMolestia    String?
  historicoMedico     String?
  medicamentosUso     String?
  alergias            String?
  exameSolicitado     String?
  exameResultado      String?
  hipoteseDiagnostica String?
  conduta             String?

  // Campos nutricionais
  historicoAlimentar  String?
  restricoes          String?
  objetivoPaciente    String?
  planoAlimentar      String?
  recordatorio24h     String?
  metas               String?

  paciente     Paciente      @relation(fields: [pacienteId], references: [id])
  clinica      Clinica       @relation(fields: [tenantId], references: [tenantId])
  profissional Profissional? @relation(fields: [profissionalId], references: [id])
  medidas      MedidaCorporal[]
  odontograma  OdontogramaItem[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("prontuario_registros")
}

model MedidaCorporal {
  id            String             @id @default(cuid())
  prontuarioId  String
  peso          Float?
  altura        Float?
  imc           Float?
  percGordura   Float?
  circAbdominal Float?
  circQuadril   Float?
  circBraco     Float?
  circCoxa      Float?
  prontuario    ProntuarioRegistro @relation(fields: [prontuarioId], references: [id], onDelete: Cascade)
  createdAt     DateTime           @default(now())

  @@map("medidas_corporais")
}

enum StatusDente {
  HIGIDO
  CARIE
  RESTAURADO
  EXTRACAO_INDICADA
  EXTRAIDO
  COROA
  IMPLANTE
  CANAL
  FRATURA
}

model OdontogramaItem {
  id             String             @id @default(cuid())
  prontuarioId   String
  pacienteId     String
  tenantId       String
  numeroDente    Int                // 11 a 48 (ISO 3950)
  status         StatusDente        @default(HIGIDO)
  facesAfetadas  Json?              // ["mesial","distal","oclusal","vestibular","lingual"]
  observacao     String?
  atualizadoPor  String?
  prontuario     ProntuarioRegistro @relation(fields: [prontuarioId], references: [id], onDelete: Cascade)
  clinica        Clinica            @relation(fields: [tenantId], references: [tenantId])
  atualizadoEm   DateTime           @updatedAt
  createdAt      DateTime           @default(now())

  @@unique([prontuarioId, numeroDente])
  @@map("odontograma_itens")
}

// Histórico de alterações do odontograma
model OdontogramaHistorico {
  id            String      @id @default(cuid())
  numeroDente   Int
  statusAnterior StatusDente?
  statusNovo    StatusDente
  observacao    String?
  alteradoPor   String?
  tenantId      String
  pacienteId    String
  clinica       Clinica     @relation(fields: [tenantId], references: [tenantId])
  createdAt     DateTime    @default(now())

  @@map("odontograma_historico")
}
