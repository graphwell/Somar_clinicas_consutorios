generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Clinica {
  id             String        @id @default(uuid())
  tenantId       String        @unique
  nome           String
  nicho          String        @default("Clínica Médica")
  configBranding Json?         // { logoUrl, primaryColor, etc }
  razaoSocial    String?
  cnpj           String?
  endereco       String?
  adminPhone     String?
  botActive      Boolean       @default(true)
  usuarios       Usuario[]
  pacientes      Paciente[]
  agendamentos   Agendamento[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("clinicas")
}

model Usuario {
  id        String   @id @default(uuid())
  email     String   @unique
  senhaHash String
  role      String   @default("recepcao") // admin, recepcao
  tenantId  String
  clinica   Clinica  @relation(fields: [tenantId], references: [tenantId])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("usuarios")
}

model Paciente {
  id           String        @id @default(uuid())
  nome         String
  telefone     String
  tenantId     String
  clinica      Clinica       @relation(fields: [tenantId], references: [tenantId])
  agendamentos Agendamento[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("pacientes")
}

model Agendamento {
  id         String   @id @default(uuid())
  pacienteId String
  dataHora   DateTime
  status     String   @default("pendente") // confirmado, pendente, cancelado, remarcado
  eventoId   String   @unique // Híbrido: hash(pacienteId + dataHora + tenantId)
  tenantId   String
  clinica    Clinica  @relation(fields: [tenantId], references: [tenantId])
  paciente   Paciente @relation(fields: [pacienteId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("agendamentos")
}
